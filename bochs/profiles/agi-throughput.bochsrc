# GENERATED PROFILE: throughput
# SUMMARY: High-throughput profile for large salience sweeps and broad search.
# SALIENCE_VECTOR: determinism=4, observability=5, throughput=10, tool_latency=9
# SOURCE: bochs/agi.bochsrc
# Generated by scripts/bochs_agi_salience_profiles.py

########################################################################
# agi.bochsrc — Bochs configuration for architecture-aware AGI research
#
# PURPOSE
# -------
# This file configures Bochs as a high-fidelity, deterministic emulation
# environment for studying how hardware architecture concepts map onto
# neural / LLM architectures (the "x86ml" framing).
#
# The emulated PC is a complete, standard-compatible x86-64 machine.
# Each configuration group is annotated with the corresponding concept
# in a transformer-based AGI system, following the structural analogy
# developed in docs/technical-architecture.md §13 and
# docs/architecture-evolution-and-llm-insights.md.
#
# ANALOGICAL MAPPING SUMMARY
# --------------------------
#   Hardware concept          ↔  Neural / AGI concept
#   ─────────────────────────────────────────────────
#   CPU instruction cycle     ↔  Forward pass (one token step)
#   Instruction decode        ↔  Embedding + attention routing
#   Register file             ↔  Activation / hidden-state tensor
#   Physical memory           ↔  Model weight tensor storage
#   iCache                    ↔  KV-cache (avoid re-computing)
#   TLB                       ↔  Sparse-attention index
#   pc_system timer slots     ↔  Scheduled async tool-calls
#   PCI / I/O devices         ↔  External tools / API endpoints
#   Interrupt controller      ↔  Asynchronous event callbacks
#   Debugger (bx_debug)       ↔  Agent introspection / explainability
#   Instrumentation hooks     ↔  Training-time gradient probes
#   .bochsrc config language  ↔  System prompt / agent configuration
#
# See docs/agi-bochsrc-guide.md for the full narrative.
########################################################################


########################################################################
# PLUGIN CONTROLLER
#
# AGI ANALOGY: selectively loading plugins is equivalent to choosing
# which "tools" are available to the agent at runtime.  Loading only
# the plugins the workload needs keeps the tool namespace lean and
# reduces the risk of spurious tool-invocation side-effects.
#
# For the AGI research configuration we load:
#   e1000      — network interface  → inference API endpoint
#   es1370     — audio / PCM device → tokenised audio stream tool
#   iodebug    — I/O debug device   → agent introspection hook
########################################################################
plugin_ctrl: e1000=1, es1370=1, iodebug=1


########################################################################
# CONFIGURATION INTERFACE
#
# AGI ANALOGY: "textconfig" gives the agent a text-only control plane,
# analogous to a JSON/CLI system-prompt interface rather than a GUI.
# This is preferred for headless, automated training runs.
########################################################################
config_interface: textconfig


########################################################################
# DISPLAY LIBRARY
#
# AGI ANALOGY: the display back-end is the agent's "observation channel"
# — the tensor of pixels that a vision model would receive.  'nogui'
# disables the channel for text-only / headless workloads; swap in
# 'sdl2' to expose a pixel tensor to a multimodal model.
#
# hideIPS suppresses per-second throughput noise from the log stream;
# the agent can query IPS programmatically via the debugger interface.
########################################################################
display_library: nogui, options="hideIPS"


########################################################################
# CPU CONFIGURATION
#
# AGI ANALOGY: the CPU is the agent's "reasoning engine" — the component
# that executes the forward pass.  Selecting the highest-fidelity model
# available (arrow_lake, the most recent Bochs CPU profile) maximises the
# number of observable architectural states, giving the agent the richest
# possible introspection surface.
#
# Key parameters:
#
#   model=arrow_lake
#     15th-Gen Intel Core Ultra — the newest and most feature-rich CPU
#     profile in Bochs (AVX-512, AMX stub, CET, PKS, …).  More CPUID
#     feature flags = more distinct "opcode handler paths" = larger
#     effective instruction vocabulary for the agent to reason about.
#
#   count=1:4:2   (1 socket × 4 cores × 2 threads = 8 vCPUs)
#     SMP configuration.  In the AGI framing, each virtual CPU is an
#     independent "attention head" that can process a distinct context
#     slice concurrently.  quantum=10 gives fine-grained interleaving
#     (analogous to a small micro-batch size).
#
#   ips=200000000
#     200 MIPS — calibrated for a modern x86-64 host.  IPS is the
#     emulator's "clock rate" and sets the cadence of all timer events
#     (PIT, RTC, APIC, …), which in turn gate asynchronous tool-calls.
#
#   reset_on_triple_fault=1
#     Deterministic recovery: on unrecoverable CPU state the machine
#     resets to a known-good checkpoint, preserving reproducibility —
#     essential for gradient-based training over emulated trajectories.
#
#   ignore_bad_msrs=1
#     Tolerate MSR accesses the emulator does not model; avoids spurious
#     #GP exceptions that would derail an agent experimenting with
#     system-level instructions.
#
#   msrs="msrs.def"
#     User-defined MSR table.  Custom MSRs can be used as a side-channel
#     for passing hyperparameters (learning rate, temperature, …) into
#     the guest environment without modifying the BIOS or kernel.
########################################################################
cpu: model=arrow_lake, count=1:4:2, quantum=64, ips=400000000, reset_on_triple_fault=1, ignore_bad_msrs=1, msrs="msrs.def"
cpu: cpuid_limit_winnt=0


########################################################################
# MEMORY CONFIGURATION
#
# AGI ANALOGY: physical RAM is the model's weight + activation tensor
# store.  Larger guest memory allows bigger in-memory model checkpoints
# (weight tensors) while the host allocation acts as the "real" working
# set (analogous to GPU VRAM vs. system RAM in a typical LLM setup).
#
#   guest=4096 MB  — exposes 4 GB address space to the guest OS
#   host=2048 MB   — pre-allocates 2 GB on the host; additional pages
#                    are demand-allocated (analogous to memory-mapped
#                    model sharding)
#   block_size=128  — 128 KB allocation granularity; small blocks allow
#                    fine-grained memory mapping of individual weight
#                    tensor shards without wasting host RAM
########################################################################
memory: guest=4096, host=1536, block_size=256


########################################################################
# ROM / BIOS
#
# AGI ANALOGY: the BIOS is the agent's "boot prompt" — the immutable
# system instructions that execute before the guest OS (the agent's
# main program) takes control.  'fastboot' skips the countdown timer,
# minimising the latency between environment reset and agent activation.
########################################################################
romimage: file=$BXSHARE/BIOS-bochs-latest, options=fastboot
vgaromimage: file=$BXSHARE/VGABIOS-lgpl/VGABIOS-lgpl-latest.bin


########################################################################
# VGA / DISPLAY
#
# AGI ANALOGY: the framebuffer is a 2-D observation tensor (H×W×3 uint8).
# update_freq=30 yields ~30 FPS — sufficient for a vision-language model
# operating at standard video rate.  realtime=1 decouples frame delivery
# from the IPS setting so the agent always sees wall-clock-consistent
# video.
########################################################################
vga: extension=vbe, update_freq=5, realtime=0, ddc=builtin_gui


########################################################################
# PCI BUS
#
# AGI ANALOGY: the PCI bus is the agent's "tool bus" — the interconnect
# over which all external tool/API adapters are discovered and addressed.
# i440fx is the most feature-complete chipset in Bochs and supports the
# full set of ACPI/HPET timers needed for fine-grained scheduling.
#
#   slot1=pcivga   — VGA tensor visualisation accelerator
#   slot2=e1000    — Gigabit NIC → HTTP/REST inference API endpoint
#   slot3=es1370   — Audio codec → audio-token pipeline
########################################################################
pci: enabled=1, chipset=i440fx, slot1=pcivga, slot2=e1000, slot3=es1370


########################################################################
# CLOCK / TIMING
#
# AGI ANALOGY: the clock governs the temporal resolution of the agent's
# world model.  'sync=slowdown' sacrifices wall-clock speed to ensure
# every emulated tick corresponds to exactly the right number of guest
# instructions — providing deterministic, reproducible trajectories
# suitable for offline reinforcement learning.
#
# time0=0  sets epoch to Unix time 0 (1970-01-01T00:00:00Z) for a
# fully reproducible starting condition regardless of host clock.
########################################################################
clock: sync=none, time0=0, rtc_sync=0


########################################################################
# STORAGE — ATA CONTROLLERS
#
# AGI ANALOGY: ATA channels are the "weight repository bus".  Each
# attached disk image can hold a different artifact:
#
#   ata0 channel  → primary model weight store (large flat image)
#   ata1 channel  → training data / dataset store (read-only CDROM ISO)
#
# IRQ assignments follow the standard PC map so any guest OS can
# enumerate the drives without custom drivers.
########################################################################
ata0: enabled=1, ioaddr1=0x1f0, ioaddr2=0x3f0, irq=14
ata1: enabled=1, ioaddr1=0x170, ioaddr2=0x370, irq=15
ata2: enabled=0, ioaddr1=0x1e8, ioaddr2=0x3e0, irq=11
ata3: enabled=0, ioaddr1=0x168, ioaddr2=0x360, irq=9

# Primary disk: model weights / checkpoint store
# SETUP REQUIRED: run scripts/bochs-agi-init.sh first to create disk images,
# then uncomment the lines below before launching Bochs.
#   bximage -func=create -hd=64000 -imgmode=growing -sectsize=512 -q weights.img
#ata0-master: type=disk, mode=growing, path="weights.img", model="ModelWeightStore"

# Secondary disk: read-only training corpus / dataset
# SETUP REQUIRED: supply an ISO image (e.g. dataset.iso) before uncommenting.
#ata0-slave: type=cdrom, path="dataset.iso", status=inserted

# Volatile scratch space for activations / intermediate tensors
# SETUP REQUIRED: run scripts/bochs-agi-init.sh to create scratch_base.img,
# then uncomment these lines.
#ata1-master: type=disk, mode=volatile, path="scratch_base.img", \
#             journal="scratch.redolog", model="ActivationScratch"


########################################################################
# BOOT SEQUENCE
#
# Boot from disk (the agent's primary OS / runtime image).
# Network boot ('network') can be used for PXE-based agent deployment
# in a multi-node distributed training cluster.
########################################################################
boot: disk


########################################################################
# SERIAL PORTS — INTER-AGENT COMMUNICATION CHANNELS
#
# AGI ANALOGY: serial ports are low-bandwidth, low-latency channels
# between agents or between an agent and its supervisor.  Socket mode
# exposes them as TCP streams, which is the standard protocol for
# GDB remote debugging and for OpenAI-compatible tool-call pipes.
#
#   com1 — supervisor ↔ agent control channel (GDB-stub or JSONL pipe)
#   com2 — agent ↔ agent message bus (multi-agent coordination)
#   com3 — structured log output for training signal capture
########################################################################
com1: enabled=1, mode=socket-server, dev=localhost:4444
com2: enabled=1, mode=socket-server, dev=localhost:4445
com3: enabled=1, mode=file, dev=throughput-agent-log.jsonl


########################################################################
# PARALLEL PORT — BULK RESULT OUTPUT
#
# AGI ANALOGY: the parallel port's 8-bit wide, DMA-driven data path
# models the agent's "result bus" — a high-throughput path for writing
# generated sequences or evaluation scores to the host environment.
########################################################################
parport1: enabled=1, file="agent-output.bin"


########################################################################
# NETWORK — INFERENCE API ENDPOINT
#
# AGI ANALOGY: the E1000 NIC is the agent's primary external API
# surface.  Packets sent to/from this NIC represent model-inference
# requests and responses (e.g., HTTP POST /v1/completions).
#
# 'ethmod=vnet' creates an isolated virtual LAN with a built-in
# DHCP/DNS/FTP server so the guest can reach the host without
# requiring host-level network privileges — important for sandboxed
# training environments.
#
# MAC address prefix b0:c4:20 is the standard Bochs OUI; the last
# three octets encode agent ID (00:00:01 = agent #1).
########################################################################
e1000: enabled=1, mac=b0:c4:20:00:00:31, ethmod=vnet, ethdev="."


########################################################################
# KEYBOARD / MOUSE
#
# Disabled for headless operation.  In an interactive demo the keyboard
# can be re-enabled and used as a human-in-the-loop override channel.
########################################################################
mouse: enabled=0
keyboard: type=mf, serial_delay=150


########################################################################
# LOGGING
#
# AGI ANALOGY: the Bochs log stream is the agent's structured "inner
# monologue" — a timestamped, module-tagged trace of every significant
# event (IRQ, DMA, memory fault, device I/O, …).  It is the primary
# data source for offline learning from emulated trajectories.
#
# logprefix encodes: tick (%t), event type (%e), device (%d), and EIP
# (%i) so each line is self-contained for ML ingestion.
########################################################################
log: bochs-agi-throughput.log
logprefix: %t-%e-@%i-%d

# Severity routing:
#   panic  → fatal (halt; preserves a clean checkpoint for analysis)
#   error  → report (logged but execution continues)
#   info   → report (rich event stream for training data)
#   debug  → ignore (too verbose for production runs; enable selectively)
panic: action=fatal
error: action=report
info: action=report
debug: action=ignore


########################################################################
# DEBUGGER
#
# AGI ANALOGY: the Bochs debugger is the agent's "introspection engine".
# It provides:
#   - Execution breakpoints  → activation checkpoints
#   - Memory watchpoints     → gradient monitoring probes
#   - Register inspection    → hidden-state readout
#   - Disassembly            → symbolic trace for chain-of-thought
#
# Log to a separate file so the debug stream can be processed
# independently from the main event log.
########################################################################
debugger: log=bochs-agi-debug.log


########################################################################
# I/O DEBUG DEVICE
#
# Writing to I/O port 0xE9 (the "magic debug port" used by many guest
# OSes and firmware) causes the string to appear in the Bochs log.
# This gives the guest a zero-overhead channel to emit structured
# observation data (e.g., JSON tool-call results) without requiring
# a full serial driver.
#
# AGI ANALOGY: equivalent to a tracing.emit() / console.log() call
# that feeds directly into the training signal pipeline.
########################################################################
port_e9_hack: enabled=1


########################################################################
# GDB STUB
#
# AGI ANALOGY: the GDB stub is a standardised remote-control interface
# for the agent's CPU state.  An external supervisor (trainer, safety
# monitor, or orchestration framework) can attach on port 1234 to:
#   - Inspect and modify register / memory state between episodes
#   - Set watchpoints that trigger reward signals
#   - Single-step through inference for alignment audits
########################################################################
gdbstub: enabled=1, port=1234, text_base=0, data_base=0, bss_base=0


########################################################################
# INSTRUMENTATION
#
# Bochs supports compile-time instrumentation hooks (instrument/) that
# fire on every instruction fetch, memory access, interrupt, and I/O
# operation — providing ~2300 observable configuration points (see
# docs/agi-bochsrc-guide.md §3 for the full enumeration).
#
# To activate, compile Bochs with:
#   ./configure --enable-instrumentation="instrument/stubs"
# and replace instrument/stubs/ with a custom implementation that
# emits the desired training signal format (e.g., protobuf, Arrow IPC).
#
# AGI ANALOGY: instrumentation hooks are gradient probes — they let
# an external training loop observe the exact sequence of micro-ops
# that produced a given output, enabling imitation learning from
# instruction traces.
########################################################################
# (instrumentation is a compile-time feature; no .bochsrc directive needed)


########################################################################
# FLOPPY DRIVES
#
# Disabled.  Floppy images can be used as a small, fast-swap "prompt
# store" — a read-only 1.44 MB image containing the agent's system
# prompt, few-shot examples, or retrieval index.
########################################################################
floppya: type=none


########################################################################
# PRIVATE COLORMAP
#
# Disabled (default).  Only relevant for X11 GUI sessions; has no
# effect in nogui / headless mode.
########################################################################
private_colormap: enabled=0


########################################################################
# FLOPPY BOOT SIGNATURE CHECK
########################################################################
floppy_bootsig_check: disabled=0
